+
+function deleteContrib(date) {
+  rpc.run
+    .withSuccessHandler(function (j) {
+      if (j && j.ok) loadContributions();
+    })
+    .withFailureHandler(function (err) {
+      console.error("deleteContrib:", err);
+    })
+    .deleteContribution(currentUser, date, sessionToken);
