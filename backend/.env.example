# Copy this file to .env and fill in real values.
# Never commit the actual .env file.

# PostgreSQL connection string (Neon gives you this after creating a project)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Long random string used to sign JWTs
JWT_SECRET=change-this-to-a-long-random-secret-string

# How long a "remember me" session stays valid, in days
REMEMBER_TOKEN_DAYS=7

PORT=3000

# Your deployed frontend URL (GitHub Pages / Cloudflare Pages), used for CORS
FRONTEND_ORIGIN=https://yourusername.github.io

# Long random string protecting /api/cron/daily-snapshot from public abuse.
# Also set this as a Vercel env var — Vercel Cron automatically sends it as
# an `Authorization: Bearer <CRON_SECRET>` header on every scheduled run.
CRON_SECRET=change-this-to-another-random-secret

# Optional: APILayer key for historical exchange rates (apilayer.com, free tier)
APILAYER_KEY=
