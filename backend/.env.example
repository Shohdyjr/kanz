# ═══════════════════════════════════════════════════════
#  Kanz backend — environment variables
#  انسخ الملف ده باسم .env واملأ القيم الحقيقية بتاعتك.
#  متعملش commit لملف .env نفسه على GitHub أبدًا (فيه أسرار).
# ═══════════════════════════════════════════════════════

# رابط قاعدة بيانات PostgreSQL (بتدّيهولك Render/Koyeb/Supabase تلقائيًا
# لما تعمل قاعدة بيانات مجانية عندهم — انسخه وحطه هنا زي ما هو)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# مفتاح سري لتوقيع JWT — حط أي نص عشوائي طويل وصعب (30+ حرف)
JWT_SECRET=change-this-to-a-long-random-secret-string

# مدة صلاحية جلسة "تذكرني" بالأيام
REMEMBER_TOKEN_DAYS=7

# البورت اللي السيرفر هيشتغل عليه (Render/Koyeb بيحددوه تلقائيًا عادة عبر PORT)
PORT=3000

# رابط الواجهة الأمامية (عشان إعدادات CORS) — حط رابط GitHub Pages/Cloudflare Pages بتاعك
FRONTEND_ORIGIN=https://yourusername.github.io

# ── إعدادات إرسال الإيميل (لتنبيهات الأسعار) ──
# أي حساب SMTP يشتغل: Gmail (App Password)، Brevo، Resend، إلخ.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM="Kanz <your-email@gmail.com>"

# ── مفتاح APILayer لسعر الصرف التاريخي (اختياري) ──
# سجّل مجانًا على apilayer.com → Exchange Rates Data API → اضغط "Subscribe for Free"
APILAYER_KEY=

# نص سري عشوائي بيحمي رابط /api/cron/price-alerts من إن أي حد يناديه من برة
# غير الخدمة الخارجية (cron-job.org). اختار أي نص طويل وصعب.
CRON_SECRET=change-this-to-another-random-secret
